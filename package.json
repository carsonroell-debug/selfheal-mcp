{
  "name": "selfheal-mcp",
  "mcpName": "io.github.carsonroell-debug/selfheal-mcp",
  "version": "0.2.0",
  "description": "Self-healing proxy for MCP servers and HTTP APIs — x402 outcome-based pricing, LLM error analysis, retry, circuit breaker, and observability",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "selfheal-mcp": "dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./sdk": "./dist/sdk.js",
    "./x402": "./dist/x402.js",
    "./heal": "./dist/heal.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "self-healing",
    "circuit-breaker",
    "retry",
    "proxy",
    "ai-agents",
    "observability",
    "x402",
    "micropayments",
    "usdc",
    "outcome-based-pricing",
    "agent-native"
  ],
  "author": "Freedom Engineers <hello@freedomengineers.tech>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/carsonroell-debug/selfheal-mcp.git"
  },
  "homepage": "https://selfheal.dev",
  "files": [
    "dist",
    "README.md",
    "selfheal.config.json",
    "selfheal.config.proxy-example.json"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
