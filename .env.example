# SelfHeal MCP — Environment Variables
# Copy to .env and fill in your values

# === Server ===
PORT=3000                                    # HTTP port (enables HTTP API + MCP SSE)

# === SelfHeal Core ===
SELFHEAL_MAX_RETRIES=3                       # Max retry attempts per call
SELFHEAL_BASE_DELAY_MS=1000                  # Base delay for exponential backoff
SELFHEAL_MAX_DELAY_MS=30000                  # Max delay cap
SELFHEAL_CIRCUIT_THRESHOLD=5                 # Consecutive failures before circuit opens
SELFHEAL_CIRCUIT_COOLDOWN_MS=120000          # Cooldown before half-open test
SELFHEAL_CONFIG=./selfheal.config.json       # Config file path

# === x402 Payment Protocol ===
X402_RECEIVING_WALLET=                        # Your USDC wallet address (Base or Solana)
X402_FACILITATOR_URL=https://x402.org/facilitator  # x402 facilitator for verify/settle
X402_NETWORKS=base,base-sepolia               # Supported networks (comma-separated)
X402_TESTNET=true                             # Set to "false" for mainnet
X402_DEADLINE_SECONDS=300                     # Payment deadline (5 min default)

# === x402 Custom Pricing (optional JSON) ===
# X402_PRICING_CONFIG='[{"name":"simple","basePrice":0.001,"maxPrice":0.002,"patterns":["400","404"]},{"name":"complex","basePrice":0.003,"maxPrice":0.005,"patterns":["429","403"]}]'

# === LLM Heal Engine ===
HEAL_LLM_API_KEY=                            # OpenAI / Anthropic / Groq API key
HEAL_LLM_PROVIDER=openai                     # Provider name (openai, anthropic, groq)
HEAL_LLM_BASE_URL=https://api.openai.com/v1  # API base URL (change for Groq, local, etc.)
HEAL_COMPLEX_MODEL=gpt-4o-mini               # Model for complex error analysis
HEAL_SIMPLE_MODEL=gpt-4o-mini                # Model for simple errors (cheaper)
HEAL_MAX_TOKENS=1024                          # Max response tokens
HEAL_MAX_BODY_SIZE=4096                       # Max body size sent to LLM (bytes)

# Shortcuts for common providers:
# OpenAI:    HEAL_LLM_BASE_URL=https://api.openai.com/v1
# Anthropic: HEAL_LLM_BASE_URL=https://api.anthropic.com/v1  (requires compatible wrapper)
# Groq:      HEAL_LLM_BASE_URL=https://api.groq.com/openai/v1
# Together:  HEAL_LLM_BASE_URL=https://api.together.xyz/v1
# Ollama:    HEAL_LLM_BASE_URL=http://localhost:11434/v1

# === Alerts & Monitoring ===
ALERT_WEBHOOK_URL=                            # Slack/Discord/generic webhook for alerts
ALERT_EMAIL=                                  # Email for critical alerts (requires SMTP)
ALERT_TRAFFIC_SPIKE_MULTIPLIER=5              # Alert when traffic > 5x baseline
ALERT_MAX_DAILY_LLM_COST=10                  # Alert when daily LLM cost > $10
ALERT_MIN_HEAL_SUCCESS_RATE=0.9              # Alert when heal success < 90%
ALERT_CHECK_INTERVAL_MS=60000                # Alert check interval (1 min)
